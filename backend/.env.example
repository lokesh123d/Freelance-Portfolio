# Backend Configuration

# Server Setup
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=*

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-firebase-db.firebaseio.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id
FIREBASE_APP_ID=your_firebase_app_id
DATABASE_URL=https://your-firebase-db.firebaseio.com

# Email Configuration (for booking & inquiry notifications)
# Get Gmail app password: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
OWNER_EMAIL=your-email@gmail.com

# Or configure any other email service (SendGrid, Mailgun, etc.)
# SENDGRID_API_KEY=your_sendgrid_api_key
# MAILGUN_API_KEY=your_mailgun_api_key
